# Configure your preferred LLM provider API key below:
# Choose either OPENAI_API_KEY or GOOGLE_API_KEY (Gemini)

OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Set preferred model provider ("openai" or "gemini")
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Optional Chroma DB persistence directory
CHROMA_PERSIST_DIR=./chroma_data
