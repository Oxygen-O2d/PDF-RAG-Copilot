{
  "manifest_version": 3,
  "name": "PDF RAG Copilot — AI Side Panel",
  "version": "1.0.1",
  "description": "Extracts text from PDF tabs locally (including file:///, web routing parameters, and Drive previews) and chats via a local RAG backend.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open PDF RAG Copilot"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js",
        "lib/*",
        "offscreen/offscreen.html",
        "offscreen/offscreen.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
