{
  "manifest_version": 3,
  "name": "PDF RAG Copilot — AI Side Panel",
  "version": "2.0.0",
  "description": "Fully self-contained PDF AI. Extracts text & OCRs scanned PDFs locally, indexes them in-browser, and chats via your own LLM API key. No backend required.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.groq.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open PDF RAG Copilot"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js",
        "offscreen/offscreen.html",
        "offscreen/offscreen.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
